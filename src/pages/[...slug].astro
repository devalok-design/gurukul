---
import BaseLayout from '../layouts/BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(guide.data.date);

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.data.title,
  description: guide.data.description,
  datePublished: guide.data.date.toISOString(),
  ...(guide.data.updatedDate && { dateModified: guide.data.updatedDate.toISOString() }),
  author: {
    '@type': 'Person',
    name: guide.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Devalok Design and Strategy Studio',
    url: 'https://devalok.in',
  },
};
---
<BaseLayout
  title={guide.data.title}
  description={guide.data.description}
  ogImage={guide.data.ogImage}
  article={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <div class="max-w-page mx-auto px-ds-06">

    <!-- Article header — cinematic, generous, editorial -->
    <header class="max-w-article pt-ds-10 pb-ds-10 border-b border-surface-border-subtle stagger-children">

      <!-- Back link — subtle, doesn't compete with the title -->
      <a
        href="/"
        class="inline-block text-ds-sm font-medium text-surface-fg-subtle uppercase tracking-ds-wide hover:text-accent-11 transition-colors duration-fast-01 ease-productive-standard"
      >
        &larr; Gurukul
      </a>

      <!-- Title area — big, bold, breathing -->
      <h1 class="mt-ds-08 font-bold text-ds-4xl sm:text-ds-5xl text-surface-fg leading-ds-tight tracking-ds-tight">
        {guide.data.title}
      </h1>

      {guide.data.subtitle && (
        <p class="mt-ds-05 text-ds-xl sm:text-ds-2xl text-surface-fg-muted leading-ds-relaxed">
          {guide.data.subtitle}
        </p>
      )}

      <!-- Author + meta — separated from title with space, editorial treatment -->
      <div class="mt-ds-08 flex flex-wrap items-center gap-x-ds-03 gap-y-ds-02 text-ds-md text-surface-fg-subtle">
        <span class="font-semibold text-surface-fg">{guide.data.author}</span>
        {guide.data.authorRole && (
          <>
            <span class="text-surface-border-strong">/</span>
            <span>{guide.data.authorRole}</span>
          </>
        )}
        <span class="text-surface-border-strong">/</span>
        <span>{formattedDate}</span>
        <span class="text-surface-border-strong">/</span>
        <span>{guide.data.readTime}</span>
      </div>

      <!-- Tags -->
      {guide.data.tags && guide.data.tags.length > 0 && (
        <div class="mt-ds-05 flex flex-wrap gap-ds-02b">
          {guide.data.tags.map((tag: string) => (
            <span class="inline-block text-ds-sm font-medium text-surface-fg-subtle bg-surface-raised border border-surface-border-subtle rounded-ds-full px-ds-03 py-ds-01">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- Content area -->
    <div class="pt-ds-10">

      {/* Mobile ToC */}
      {tocHeadings.length > 0 && (
        <details class="xl:hidden mb-ds-10 max-w-article border border-surface-border-subtle rounded-ds-md">
          <summary class="cursor-pointer px-ds-05 py-ds-04 text-ds-sm font-semibold text-surface-fg-subtle select-none uppercase tracking-ds-wide">
            Contents
          </summary>
          <ul class="px-ds-05 pb-ds-04 space-y-ds-02b">
            {tocHeadings.map((h) => (
              <li>
                <a
                  href={`#${h.slug}`}
                  class:list={[
                    'block text-ds-sm leading-ds-relaxed text-surface-fg-subtle hover:text-accent-11 transition-colors duration-fast-01 ease-productive-standard',
                    h.depth === 3 && 'pl-ds-04',
                  ]}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </details>
      )}

      <div class="flex gap-ds-12">
        <article class="prose-gurukul max-w-article min-w-0 flex-1">
          <Content />
        </article>
        <aside class="w-56 shrink-0 hidden xl:block">
          <TableOfContents headings={headings} />
        </aside>
      </div>
    </div>

    <!-- End of article -->
    <div class="max-w-article py-ds-13">
      <div class="h-[1px] bg-surface-border-subtle mb-ds-08"></div>
      <a
        href="/"
        class="inline-block text-ds-md font-semibold text-accent-11 hover:text-accent-12 transition-colors duration-fast-01 ease-productive-standard"
      >
        &larr; All guides
      </a>
    </div>
  </div>
</BaseLayout>
